# SELFIE AI™ Environment Configuration
# Copy this file to .env.local and fill in the actual values

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Authentication
NEXTAUTH_SECRET=your-nextauth-secret-here
NEXTAUTH_URL=http://localhost:3000

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key-here

# Replicate Configuration (for AI image generation)
REPLICATE_API_TOKEN=your-replicate-token-here

# Stripe Configuration (for payments)
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key-here
STRIPE_SECRET_KEY=your-stripe-secret-key-here
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret-here

# Email Configuration (using Resend)
RESEND_API_KEY=your-resend-api-key-here
FROM_EMAIL=noreply@yourdomain.com

# Make.com Integration (for automation)
MAKE_WEBHOOK_URL=your-make-webhook-url-here
MAKE_API_KEY=your-make-api-key-here

# File Upload Configuration
NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=avatars
NEXT_PUBLIC_MAX_FILE_SIZE=5242880

# Analytics & Tracking
GOOGLE_ANALYTICS_ID=your-google-analytics-id-here
FACEBOOK_PIXEL_ID=your-facebook-pixel-id-here

# Social Media Integration
INSTAGRAM_CLIENT_ID=your-instagram-client-id-here
INSTAGRAM_CLIENT_SECRET=your-instagram-client-secret-here

# Development Settings
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin Configuration
ADMIN_EMAIL=ssa@ssasocial.com
ADMIN_PASSWORD=your-admin-password-here

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# AI Model Configuration
DEFAULT_AI_MODEL=gpt-4-turbo-preview
FALLBACK_AI_MODEL=gpt-3.5-turbo

# Feature Flags
FEATURE_VIP_ACCESS=true
FEATURE_BETA_TOOLS=false
FEATURE_ANALYTICS=true
