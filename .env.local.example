# SSELFIE Environment Variables
# Copy this file to .env.local and fill in your actual values

# ===========================================
# SUPABASE CONFIGURATION
# ===========================================
# Get these from your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ===========================================
# STRIPE PAYMENT CONFIGURATION
# ===========================================
# Get these from your Stripe dashboard
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret

# ===========================================
# OPENAI CONFIGURATION
# ===========================================
# For Sandra AI and content generation
OPENAI_API_KEY=sk-your_openai_api_key

# ===========================================
# EMAIL CONFIGURATION (RESEND)
# ===========================================
# For transactional emails
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=sandra@sselfie.ai

# ===========================================
# FILE UPLOAD CONFIGURATION (UPLOADCARE)
# ===========================================
# For image uploads and processing
NEXT_PUBLIC_UPLOADCARE_PUBLIC_KEY=your_uploadcare_public_key
UPLOADCARE_SECRET_KEY=your_uploadcare_secret_key

# ===========================================
# APP CONFIGURATION
# ===========================================
# Your app's URL (for webhooks and redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=SSELFIE

# ===========================================
# SANDRA AI CONFIGURATION
# ===========================================
# System prompt for Sandra AI responses
SANDRA_AI_SYSTEM_PROMPT="You are Sandra, the founder of SSELFIE. You're a former hairdresser and single mom who built a 120K following. You speak like Rachel from Friends but about personal branding. You're warm, direct, and authentically helpful."

# ===========================================
# ANALYTICS & MONITORING (OPTIONAL)
# ===========================================
# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Vercel Analytics
NEXT_PUBLIC_VERCEL_ANALYTICS=true

# ===========================================
# DEVELOPMENT ONLY
# ===========================================
# Set to 'development' for local dev
NODE_ENV=development

# Enable debug logging
DEBUG=true

# Skip email sending in development
SKIP_EMAILS=true
