import { Resend } from 'resend';

// Initialize Resend
const resend = new Resend(process.env.RESEND_API_KEY!);

interface EmailPayload {
  type: string;
  to: string;
  data: Record<string, any>;
}

interface EmailResult {
  success: boolean;
  emailId?: string;
  error?: string;
}

const FROM_EMAIL = 'Sandra <sandra@selfieai.com>';
const REPLY_TO = 'support@selfieai.com';

export async function sendEmail(payload: EmailPayload): Promise<EmailResult> {
  console.log(`📧 Sending email: ${payload.type} to ${payload.to}`);

  try {
    const emailContent = generateEmailContent(payload.type, payload.data);
    
    const result = await resend.emails.send({
      from: FROM_EMAIL,
      to: payload.to,
      replyTo: REPLY_TO,
      subject: emailContent.subject,
      html: emailContent.html
    });

    console.log(`✅ Email sent successfully: ${result.id}`);
    
    return {
      success: true,
      emailId: result.id
    };

  } catch (error) {
    console.error('❌ Email send error:', error);
    
    return {
      success: false,
      error: error instanceof Error ? error.message : 'Failed to send email'
    };
  }
}

function generateEmailContent(type: string, data: Record<string, any>) {
  switch (type) {
    case 'purchase_welcome':
      return generatePurchaseWelcomeEmail(data);
    
    case 'free_guide_confirmation':
      return generateFreeGuideConfirmationEmail(data);
    
    default:
      throw new Error(`Unknown email type: ${type}`);
  }
}

