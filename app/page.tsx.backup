            <div className="relative">
              <div className="bg-white/5 backdrop-blur-sm border border-white/10 p-12">
                <div className="absolute -top-20 -right-10 text-xs tracking-[0.3em] uppercase text-white/30">
                  The Shift
                </div>
                <h3 className="font-bodoni text-4xl tracking-[-0.04em] mb-6">
