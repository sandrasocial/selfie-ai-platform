            {/* Scroll Indicator */}
            <div className={`absolute bottom-10 left-1/2 transform -translate-x-1/2 opacity-0 animate-fadeInUp animation-delay-2s ${heroLoaded ? 'animate-fadeInUp' : ''}`}>
