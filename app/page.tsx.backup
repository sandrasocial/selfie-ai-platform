                  className="magnetic-button border border-white/30 px-12 py-5 text-sm tracking-[0.3em] uppercase luxury-hover hover:border-white group relative overflow-hidden focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-[#171719]"
                >
