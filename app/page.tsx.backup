          <div className="absolute top-0 w-full h-full bg-gradient-to-b from-transparent via-white/20 to-transparent animate-pulse" />
        </div>
        
        {/* Decorative Elements */}
        <div className="absolute top-20 right-20 w-32 h-32 border border-white/10 rotate-45 animate-float animation-delay-2s" />
        <div className="absolute bottom-20 left-40 w-20 h-20 border border-white/10 animate-float animation-delay-4s" />
        
        <div className="container mx-auto px-6 md:px-12 relative z-10">
